{
  "name": "generalFlow",
  "node_definition": [{
    "id": "start",
    "name": "开始",
    "auto": true,
    "state": "completed",
    "debug": false,
    "variables": {}
  }, {
    "id": "step1",
    "name": "校验或数据预处理",
    "auto": true,
    "state": "completed",
    "debug": true,
    "variables": {}
  }, {
    "id": "branch1",
    "name": "结果",
    "auto": true,
    "state": "completed",
    "exec_mode": "serial",
    "debug": false,
    "variables": {}
  }, {
    "id": "branch2",
    "name": "是否还有校验及数据预处理",
    "auto": true,
    "state": "completed",
    "exec_mode": "serial",
    "debug": false,
    "variables": {}
  }, {
    "id": "step2",
    "name": "保存/更新/删除",
    "auto": true,
    "state": "completed",
    "debug": false,
    "variables": {}
  }, {
    "id": "end",
    "name": "结束",
    "auto": true,
    "state": "completed",
    "debug": false,
    "variables": {}
  }],
  "node_link": [{
    "id": "link1",
    "name": "to校验或数据预处理",
    "from": "start",
    "to": "step1",
    "variables": {}
  }, {
    "id": "link2",
    "name": "to结果",
    "from": "step1",
    "to": "branch1",
    "variables": {}
  }, {
    "id": "link3",
    "name": "to结束",
    "from": "branch1",
    "to": "end",
    "variables": {
      "conditions": {
        "branch_condition": {
          "formula": "$errorCode=1"
        }
      }
    }
  }, {
    "id": "link4",
    "name": "to是否还有校验及数据预处理",
    "from": "branch1",
    "to": "branch2",
    "variables": {
      "conditions": {
        "branch_condition": {
          "formula": "$errorCode=0"
        }
      }
    }
  }, {
    "id": "link5",
    "name": "to校验及数据预处理",
    "from": "branch2",
    "to": "step1",
    "variables": {
      "conditions": {
        "branch_condition": {
          "formula": "$num>0"
        }
      }
    }
  }, {
    "id": "link6",
    "name": "to保存/更新/删除",
    "from": "branch2",
    "to": "step2",
    "variables": {
      "conditions": {
        "branch_condition": {
          "formula": "$num=0"
        }
      }
    }
  }, {
    "id": "link7",
    "name": "to结束",
    "from": "step2",
    "to": "end",
    "variables": {}
  }]
}
