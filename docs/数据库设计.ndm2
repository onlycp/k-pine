            "DDL": "CREATE TABLE `sys_data_access_user` (\n  `id` varchar(32) COLLATE utf8mb4_bin NOT NULL COMMENT '主键',\n  `sys_user_id` varchar(32) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '用户id',\n  `sys_data_access_id` varchar(50) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '数据访问组id',\n  `who_created` varchar(32) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '创建人员',\n  `when_created` varchar(20) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '创建时间',\n  PRIMARY KEY (`id`),\n  KEY `fk_sys_data_access_group_user` (`sys_user_id`),\n  KEY `fk_sys_data_access_group_group_id` (`sys_data_access_id`),\n  CONSTRAINT `fk_sys_data_access_group_group_id` FOREIGN KEY (`sys_data_access_id`) REFERENCES `sys_data_access` (`id`) ON DELETE NO ACTION ON UPDATE NO ACTION,\n  CONSTRAINT `fk_sys_data_access_group_user` FOREIGN KEY (`sys_user_id`) REFERENCES `sys_user` (`id`) ON DELETE NO ACTION ON UPDATE NO ACTION\n) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_bin COMMENT='系统表-用户和数据访问组'",
