            "DDL": "CREATE TABLE `sys_config` (\n  `id` varchar(36) COLLATE utf8mb4_bin NOT NULL COMMENT 'ID',\n  `name` varchar(255) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '参数名称',\n  `code` varchar(255) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '参数键名',\n  `value` varchar(255) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '参数键值',\n  `is_sys` tinyint(4) DEFAULT NULL COMMENT '是否系统内置',\n  `note` varchar(255) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '备注',\n  `who_created` varchar(32) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '创建人员',\n  `when_created` varchar(20) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '创建时间',\n  `who_modified` varchar(32) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '修改人员',\n  `when_modified` varchar(20) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '修改时间',\n  `value_type` tinyint(4) DEFAULT '0'\n) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_bin",
