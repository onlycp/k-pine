            "DDL": "CREATE TABLE `sys_menu` (\n  `id` varchar(32) COLLATE utf8mb4_bin NOT NULL COMMENT '主键',\n  `name` varchar(50) COLLATE utf8mb4_bin NOT NULL COMMENT '名称',\n  `parent_id` varchar(32) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '上级菜单ID',\n  `icon` varchar(50) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '图标',\n  `code` varchar(50) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '编码',\n  `router_path` varchar(255) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '路由路径',\n  `component_path` varchar(255) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '组件路径',\n  `is_hidden` tinyint(4) NOT NULL DEFAULT '0' COMMENT '是否隐藏',\n  `menu_type` char(1) COLLATE utf8mb4_bin NOT NULL DEFAULT '0' COMMENT '菜单类型（M目录 C菜单 F按钮）',\n  `api_codes` varchar(255) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '接口编码，多个用逗号分隔',\n  `open_mode` tinyint(4) NOT NULL COMMENT '打开方式 0:页签 1:新窗口',\n  `keep_alive` tinyint(4) DEFAULT NULL COMMENT '是否刷新 0: 否 1：是',\n  `path` text COLLATE utf8mb4_bin NOT NULL COMMENT '菜单层级关系，自动生成',\n  `order_num` int(4) NOT NULL DEFAULT '0' COMMENT '排序',\n  `status` tinyint(4) NOT NULL DEFAULT '1' COMMENT '可用状态',\n  `who_created` varchar(32) COLLATE utf8mb4_bin NOT NULL COMMENT '创建人员',\n  `when_created` varchar(20) COLLATE utf8mb4_bin NOT NULL COMMENT '创建时间',\n  `who_modified` varchar(32) COLLATE utf8mb4_bin NOT NULL COMMENT '修改人员',\n  `when_modified` varchar(20) COLLATE utf8mb4_bin NOT NULL COMMENT '修改时间',\n  PRIMARY KEY (`id`) USING BTREE\n) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_bin COMMENT='系统表-菜单'",
