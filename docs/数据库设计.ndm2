            "updateTime": "2022-02-24 17:17:42",
            "DDL": "CREATE TABLE `kw_receipt` (\n  `id` varchar(36) COLLATE utf8mb4_bin NOT NULL COMMENT '主键',\n  `account_id` varchar(36) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '账户id',\n  `file_id` varchar(36) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '数据库文件路径',\n  `receipt_number` varchar(100) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '电子回单号码',\n  `book_date` timestamp NULL DEFAULT NULL COMMENT '记帐日期',\n  `drawee_name` varchar(100) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '付款人姓名',\n  `drawee_account_number` varchar(100) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '付款人帐号',\n  `drawee_bank` varchar(100) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '付款人开户银行',\n  `payee_name` varchar(100) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '收款人姓名',\n  `payee_account_number` varchar(100) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '收款人帐号',\n  `amount` varchar(100) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '金额元',\n  `abstract_info` varchar(255) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '摘要',\n  `purpose` varchar(255) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '用途',\n  `currency` int(11) DEFAULT NULL COMMENT '币种',\n  `code` varchar(255) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '验证码',\n  `file_path` varchar(255) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '回单文件路径',\n  `source` int(11) DEFAULT NULL COMMENT '回单来源',\n  `other_data` longtext COLLATE utf8mb4_bin COMMENT '其他数据',\n  `status` int(11) DEFAULT '0' COMMENT '数据状态',\n  `has_water` int(11) DEFAULT '0' COMMENT '是否有流水',\n  `register_time` timestamp NULL DEFAULT NULL COMMENT '登记时间',\n  `serial_number` varchar(50) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '流水号',\n  `payee_bank` varchar(100) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '收款人开户银行',\n  `deleted` tinyint(4) DEFAULT '0' COMMENT '删除标识',\n  `self_account` varchar(100) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '归属账号',\n  `date_index` int(11) DEFAULT NULL COMMENT '数据序号',\n  PRIMARY KEY (`id`)\n) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_bin COMMENT='回单表'",
