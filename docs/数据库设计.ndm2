            "DDL": "CREATE TABLE `biz_xzicpp_person_expand` (\n  `id` varchar(255) COLLATE utf8mb4_bin NOT NULL COMMENT 'id',\n  `identity` varchar(255) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '身份',\n  `province` varchar(255) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '所在省市',\n  `company_name` varchar(255) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '单位名称',\n  `address` varchar(255) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '详细地址',\n  `regtime` varchar(255) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '注册时间',\n  `qualification` varchar(255) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '资质',\n  `specification` varchar(255) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '仪器规格',\n  `requirements` varchar(255) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '测试须知',\n  `supplier` varchar(255) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '供应商',\n  `price` varchar(255) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '价格',\n  `image` varchar(255) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '图片',\n  `shelf_status` varchar(255) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '上架状态',\n  `average_time` varchar(255) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '平均时长',\n  `satisfaction` varchar(255) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '满意度',\n  `service_times` varchar(255) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '服务次数',\n  PRIMARY KEY (`id`)\n) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_bin",
