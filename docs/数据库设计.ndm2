            "DDL": "CREATE TABLE `biz_xzicpp_order` (\n  `id` varchar(255) COLLATE utf8mb4_bin NOT NULL COMMENT 'id',\n  `equipment_id` varchar(255) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '关联设备ID',\n  `number` varchar(255) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '编号',\n  `stage` varchar(255) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '阶段',\n  `time_requirement_begin` timestamp(6) NULL DEFAULT NULL COMMENT '时间需求（始）',\n  `time_requirement_end` timestamp(6) NULL DEFAULT NULL COMMENT '时间需求（终）',\n  `chip_type` varchar(255) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '芯片型号',\n  `cnt` varchar(255) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '数量',\n  `unit` varchar(255) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '单位',\n  `inspect_way` varchar(255) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '送检方式',\n  `person_contact` varchar(255) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '联系人',\n  `phone` varchar(255) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '联系电话',\n  `express_number` varchar(255) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '快递单号',\n  `test_requirement` varchar(255) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '测试需求',\n  `accessory` varchar(255) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '附件',\n  `person_start` varchar(255) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '发起人',\n  `time_start` timestamp(6) NULL DEFAULT NULL COMMENT '发起时间',\n  `person_receive` varchar(255) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '接单人',\n  `time_receive` timestamp(6) NULL DEFAULT NULL COMMENT '接单时间',\n  `result_receive` varchar(255) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '接单结果',\n  `reason_refused` varchar(255) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '拒接原因',\n  `time_test_begin` timestamp(6) NULL DEFAULT NULL COMMENT '开始测试时间',\n  `time_test_end` timestamp(6) NULL DEFAULT NULL COMMENT '测试结束时间',\n  `result_test` varchar(255) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '测试结果',\n  `result_confirm` varchar(255) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '结果确认',\n  `person_confirm` varchar(255) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '确认人',\n  `time_confirm` timestamp(6) NULL DEFAULT NULL COMMENT '确认时间',\n  `duration_of_use` varchar(255) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '使用时长',\n  `price` varchar(255) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '价格',\n  PRIMARY KEY (`id`)\n) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_bin",
