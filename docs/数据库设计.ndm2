            "updateTime": "2022-02-14 03:53:20",
            "DDL": "CREATE TABLE `dev_application` (\n  `id` varchar(36) COLLATE utf8mb4_bin NOT NULL COMMENT '应用ID',\n  `name` varchar(100) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '应用名',\n  `short_name` varchar(30) COLLATE utf8mb4_bin NOT NULL COMMENT '应用短英文名（用于数据库等前缀命名），- 必须唯一，- 必须为纯英文、小写字母命名\\n- 用于创建业务目录、数据库，',\n  `description` varchar(255) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '应用介绍',\n  `enable_status` tinyint(1) DEFAULT NULL COMMENT '可用状态',\n  `dev_status` tinyint(1) DEFAULT NULL COMMENT '开发状态，0: 新建1: 确认版本2: 有更新',\n  `version` varchar(50) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '当前发布版本',\n  `who_in_charge` varchar(255) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '负责人',\n  `system_logo` varchar(255) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '应用图标',\n  `app_type` varchar(100) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '应用类型：可多个，逗号分隔，0: PC Web应用，1：移动端Web应用，2： 小程序，3： APP',\n  `default_path` varchar(255) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '默认路径',\n  `deleted` tinyint(1) NOT NULL DEFAULT '0' COMMENT '是否已删除',\n  `when_created` timestamp NULL DEFAULT NULL COMMENT '创建时间',\n  `who_created` varchar(36) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '创建人',\n  `when_modified` timestamp NULL DEFAULT NULL COMMENT '修改时间',\n  `who_modified` varchar(36) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '修改人',\n  PRIMARY KEY (`id`)\n) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_bin",
