            "DDL": "CREATE TABLE `kw_bank_account_expand` (\n  `id` varchar(36) COLLATE utf8mb4_bin NOT NULL COMMENT '主键',\n  `bank_account_id` varchar(36) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '账户id',\n  `account` varchar(50) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '项目账户',\n  `pro_num` varchar(36) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '项目编号',\n  `pro_name` varchar(100) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '项目名称',\n  `pro_pm` varchar(255) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '项目经理',\n  `pro_pm_account` varchar(36) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '项目经理账号',\n  `trust_accounting` varchar(50) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '信托会计',\n  `trust_accounting_account` varchar(100) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '信托会计账号',\n  `down_date` timestamp NULL DEFAULT NULL COMMENT '项目下架日期',\n  `up_date` timestamp NULL DEFAULT NULL COMMENT '项目上架日期',\n  `in_date` timestamp NULL DEFAULT NULL COMMENT '项目录入日期',\n  `when_created` timestamp NULL DEFAULT NULL COMMENT '创建时间',\n  `when_modified` timestamp NULL DEFAULT NULL COMMENT '修改时间',\n  `who_created` varchar(36) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '创建人',\n  `who_modified` varchar(36) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '修改人',\n  `reserve1` varchar(255) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '备用字段1',\n  `reserve2` varchar(255) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '备用字段2',\n  `reserve3` varchar(255) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '备用字段3',\n  `reserve4` varchar(255) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '备用字段4',\n  `reserve5` varchar(255) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '备用字段5',\n  `pro_phase` varchar(50) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '项目阶段',\n  PRIMARY KEY (`id`)\n) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_bin COMMENT='项目扩展表'",
