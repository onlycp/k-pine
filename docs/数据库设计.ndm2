            "DDL": "CREATE TABLE `biz_monitor_data_tencent_cloud` (\n  `id` varchar(36) COLLATE utf8mb4_bin NOT NULL COMMENT '主键',\n  `monitor_id` varchar(50) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '外键(biz_monitor.id)',\n  `data_id` varchar(50) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '外键(biz_monitor_data.id)',\n  `sessionId` varchar(500) COLLATE utf8mb4_bin DEFAULT NULL,\n  `alarmStatus` varchar(500) COLLATE utf8mb4_bin DEFAULT NULL,\n  `alarmType` varchar(500) COLLATE utf8mb4_bin DEFAULT NULL,\n  `region` varchar(500) COLLATE utf8mb4_bin DEFAULT NULL,\n  `namespace` varchar(500) COLLATE utf8mb4_bin DEFAULT NULL,\n  `dimensions` varchar(500) COLLATE utf8mb4_bin DEFAULT NULL,\n  `policyId` varchar(500) COLLATE utf8mb4_bin DEFAULT NULL,\n  `policyType` varchar(500) COLLATE utf8mb4_bin DEFAULT NULL,\n  `policyName` varchar(500) COLLATE utf8mb4_bin DEFAULT NULL,\n  `policyTypeCName` varchar(500) COLLATE utf8mb4_bin DEFAULT NULL,\n  `metricName` varchar(500) COLLATE utf8mb4_bin DEFAULT NULL,\n  `metricShowName` varchar(500) COLLATE utf8mb4_bin DEFAULT NULL,\n  `calcType` varchar(500) COLLATE utf8mb4_bin DEFAULT NULL,\n  `calcValue` varchar(500) COLLATE utf8mb4_bin DEFAULT NULL,\n  `calcUnit` varchar(500) COLLATE utf8mb4_bin DEFAULT NULL,\n  `currentValue` varchar(500) COLLATE utf8mb4_bin DEFAULT NULL,\n  `historyValue` varchar(500) COLLATE utf8mb4_bin DEFAULT NULL,\n  `unit` varchar(500) COLLATE utf8mb4_bin DEFAULT NULL,\n  `period` varchar(500) COLLATE utf8mb4_bin DEFAULT NULL,\n  `periodNum` varchar(500) COLLATE utf8mb4_bin DEFAULT NULL,\n  `productName` varchar(500) COLLATE utf8mb4_bin DEFAULT NULL,\n  `productShowName` varchar(500) COLLATE utf8mb4_bin DEFAULT NULL,\n  `eventName` varchar(500) COLLATE utf8mb4_bin DEFAULT NULL,\n  `eventShowName` varchar(500) COLLATE utf8mb4_bin DEFAULT NULL,\n  `alarmNotifyType` varchar(500) COLLATE utf8mb4_bin DEFAULT NULL,\n  `alarmNotifyPeriod` varchar(500) COLLATE utf8mb4_bin DEFAULT NULL,\n  `firstOccurTime` varchar(500) COLLATE utf8mb4_bin DEFAULT NULL,\n  `durationTime` varchar(500) COLLATE utf8mb4_bin DEFAULT NULL,\n  `recoverTime` varchar(500) COLLATE utf8mb4_bin DEFAULT NULL,\n  `who_created` varchar(32) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '创建人员',\n  `when_created` timestamp NULL DEFAULT NULL COMMENT '创建时间',\n  `who_modified` varchar(32) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '修改人员',\n  `when_modified` timestamp NULL DEFAULT NULL COMMENT '修改时间',\n  PRIMARY KEY (`id`),\n  KEY `data_id` (`data_id`),\n  KEY `monitor_id` (`monitor_id`)\n) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_bin COMMENT='监控数据-结果转换表'",
