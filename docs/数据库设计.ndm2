            "DDL": "CREATE TABLE `sys_unit` (\n  `id` varchar(32) COLLATE utf8mb4_bin NOT NULL COMMENT '主键',\n  `name` varchar(50) COLLATE utf8mb4_bin NOT NULL COMMENT '名称',\n  `parent_id` varchar(32) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '上级单位ID',\n  `path` text COLLATE utf8mb4_bin NOT NULL COMMENT '层次关系，自动生成',\n  `leader` varchar(255) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '负责人',\n  `mobile` varchar(20) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '联系电话',\n  `email` varchar(50) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '电子邮箱',\n  `status` tinyint(4) NOT NULL DEFAULT '1' COMMENT '部门状态， 0：停用 1：正常',\n  `note` text COLLATE utf8mb4_bin COMMENT '备注',\n  `order_num` int(10) DEFAULT '0' COMMENT '排序 ',\n  `who_created` varchar(32) COLLATE utf8mb4_bin NOT NULL COMMENT '创建人员',\n  `when_created` varchar(20) COLLATE utf8mb4_bin NOT NULL COMMENT '创建时间',\n  `who_modified` varchar(32) COLLATE utf8mb4_bin NOT NULL COMMENT '修改人员',\n  `when_modified` varchar(20) COLLATE utf8mb4_bin NOT NULL COMMENT '修改时间',\n  PRIMARY KEY (`id`) USING BTREE\n) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_bin COMMENT='系统表-单位机构'",
