            "DDL": "CREATE TABLE `dev_page` (\n  `id` varchar(36) COLLATE utf8mb4_bin NOT NULL COMMENT '主键',\n  `when_created` timestamp NULL DEFAULT NULL COMMENT '创建时间',\n  `when_modified` timestamp NULL DEFAULT NULL COMMENT '修改时间',\n  `who_created` varchar(36) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '创建人',\n  `who_modified` varchar(36) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '修改人',\n  `deleted` tinyint(4) DEFAULT '0' COMMENT '删除标识',\n  `app_id` varchar(36) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '应用ID',\n  `name` varchar(255) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '页面名称',\n  `description` varchar(255) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '页面介绍',\n  `path` varchar(255) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '访问路径 ',\n  `app_type` varchar(100) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '应用类型：可多个，逗号分隔，0: PC Web应用，1：移动端Web应用，2： 小程序，3： APP',\n  `login_required` tinyint(1) DEFAULT NULL COMMENT '是否需要登录才可以访问',\n  `enable_status` tinyint(1) DEFAULT NULL COMMENT '可用状态',\n  `dev_status` tinyint(1) DEFAULT NULL COMMENT '开发状态',\n  `page_json` longtext COLLATE utf8mb4_bin COMMENT '页面数据化JSON',\n  PRIMARY KEY (`id`)\n) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_bin",
