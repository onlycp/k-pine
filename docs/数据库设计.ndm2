            "updateTime": "2022-02-23 16:43:19",
            "DDL": "CREATE TABLE `sys_user` (\n  `id` varchar(36) COLLATE utf8mb4_bin NOT NULL COMMENT '主键',\n  `username` varchar(50) COLLATE utf8mb4_bin NOT NULL COMMENT '用户名',\n  `password` varchar(256) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '密码',\n  `real_name` varchar(50) COLLATE utf8mb4_bin NOT NULL COMMENT '用户姓名',\n  `mobile` varchar(20) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '手机号码',\n  `email` varchar(50) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '电子邮箱',\n  `sex` tinyint(4) DEFAULT NULL COMMENT '性别 0:男 1:女',\n  `sys_unit_id` varchar(32) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '归属部门',\n  `post` varchar(50) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '岗位',\n  `status` tinyint(4) DEFAULT '1' COMMENT '状态 1：正常 0：禁用',\n  `note` text COLLATE utf8mb4_bin COMMENT '备注',\n  `who_created` varchar(32) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '创建人员',\n  `when_created` varchar(20) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '创建时间',\n  `who_modified` varchar(32) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '修改人员',\n  `when_modified` varchar(20) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '修改时间',\n  `deleted` tinyint(4) DEFAULT '0' COMMENT '逻辑删除 0:正常 1：删除',\n  `avatar` varchar(255) COLLATE utf8mb4_bin DEFAULT NULL,\n  PRIMARY KEY (`id`) USING BTREE,\n  UNIQUE KEY `idx_username_uindex` (`username`) USING BTREE,\n  KEY `fk_sys_unit_id` (`sys_unit_id`) USING BTREE,\n  CONSTRAINT `fk_sys_unit_id` FOREIGN KEY (`sys_unit_id`) REFERENCES `sys_unit` (`id`)\n) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_bin COMMENT='系统表-用户'",
