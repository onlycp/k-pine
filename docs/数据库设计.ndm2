            "DDL": "CREATE TABLE `biz_xzicpp_company` (\n  `id` varchar(65) COLLATE utf8mb4_bin NOT NULL COMMENT 'id',\n  `name` varchar(255) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '企业名称',\n  `logo` varchar(255) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '企业logo',\n  `business_license` varchar(255) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '营业执照图片',\n  `id_card` varchar(255) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '法定身份证复印件',\n  `person_responsible` varchar(255) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '经办人',\n  `phone` varchar(255) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '联系电话',\n  `time` timestamp(6) NULL DEFAULT NULL COMMENT '注册时间',\n  `code` varchar(255) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '企业统一社会信用代码',\n  `audit_status` tinyint(255) DEFAULT NULL COMMENT '审核状态',\n  `reviewer` varchar(255) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '审核人',\n  `audit_time` timestamp(6) NULL DEFAULT NULL COMMENT '审核时间',\n  `refuse_reason` varchar(255) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '拒绝理由',\n  `user_id` varchar(255) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '用户id',\n  `satisfaction` decimal(65,0) DEFAULT NULL COMMENT '满意度',\n  `service_times` int(255) DEFAULT NULL COMMENT '服务次数',\n  PRIMARY KEY (`id`)\n) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_bin",
