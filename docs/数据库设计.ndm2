            "DDL": "CREATE TABLE `kw_edition` (\n  `id` varchar(36) COLLATE utf8mb4_bin NOT NULL COMMENT '版本',\n  `mechanism_id` varchar(36) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '机构id',\n  `name` varchar(255) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '版本名称',\n  `password_max_retried` int(11) DEFAULT NULL COMMENT '密码最大错误次数',\n  `ukey` int(11) DEFAULT NULL COMMENT '是否有',\n  `path` varchar(255) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '访问路径',\n  `bank_type` varchar(255) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '系统类型',\n  `status` int(11) DEFAULT NULL COMMENT '版本状态',\n  `description` varchar(2000) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '版本说明',\n  `deleted` tinyint(4) DEFAULT '0' COMMENT '是否删除',\n  `when_created` timestamp NULL DEFAULT NULL COMMENT '创建时间',\n  `when_modified` timestamp NULL DEFAULT NULL COMMENT '修改时间',\n  `who_created` varchar(36) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '创建人',\n  `who_modified` varchar(36) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '修改人',\n  `reserve1` varchar(255) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '备用字段1',\n  `reserve2` varchar(255) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '备用字段2',\n  `reserve3` varchar(255) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '备用字段3',\n  `reserve4` varchar(255) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '备用字段4',\n  `reserve5` varchar(255) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '备用字段5',\n  PRIMARY KEY (`id`)\n) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_bin COMMENT='银行版本管理'",
