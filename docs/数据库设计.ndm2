            "DDL": "CREATE TABLE `kw_mbs_water_result` (\n  `id` varchar(36) COLLATE utf8mb4_bin NOT NULL COMMENT '= 流水id',\n  `flag` varchar(36) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '接收结果',\n  `message` varchar(255) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '接收结果信息',\n  `retries` int(11) DEFAULT NULL COMMENT 'mbs流水发送重试次数',\n  `when_created` timestamp NULL DEFAULT NULL COMMENT '创建时间',\n  `when_modified` timestamp NULL DEFAULT NULL COMMENT '修改时间',\n  `who_created` varchar(36) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '创建人',\n  `who_modified` varchar(36) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '修改人',\n  `deleted` tinyint(4) DEFAULT '0' COMMENT '是否删除',\n  PRIMARY KEY (`id`)\n) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_bin COMMENT='推送浦发系统结果表'",
