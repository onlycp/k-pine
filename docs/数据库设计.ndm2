            "DDL": "CREATE TABLE `kw_bank_account` (\n  `id` varchar(36) COLLATE utf8mb4_bin NOT NULL COMMENT '主键',\n  `edition_id` varchar(36) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '版本id',\n  `account` varchar(50) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '账户',\n  `account_type` int(11) DEFAULT NULL COMMENT '账户类型',\n  `cxpl` varchar(36) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '账户查询频率',\n  `bank_deposit` varchar(255) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '开户行',\n  `status` int(11) DEFAULT NULL COMMENT '账户状态',\n  `data_source` int(11) DEFAULT NULL COMMENT '数据来源',\n  `deleted` tinyint(4) DEFAULT '0' COMMENT '删除标识',\n  `create_account_time` timestamp NULL DEFAULT NULL COMMENT '开户时间',\n  `cancel_account_time` timestamp NULL DEFAULT NULL COMMENT '销户时间',\n  `when_created` timestamp NULL DEFAULT NULL COMMENT '创建时间',\n  `when_modified` timestamp NULL DEFAULT NULL COMMENT '修改时间',\n  `who_created` varchar(36) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '创建人',\n  `who_modified` varchar(36) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '修改人',\n  `reserve1` varchar(255) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '备用字段1',\n  `reserve2` varchar(255) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '备用字段2',\n  `reserve3` varchar(255) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '备用字段3',\n  `reserve4` varchar(255) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '备用字段4',\n  `reserve5` varchar(255) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '备用字段5',\n  `relation_type` int(11) DEFAULT NULL COMMENT '关联类型：0待选择默认值；<br>1为单位；<br>2为项目；',\n  `relation_id` varchar(36) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '关联id',\n  `mbs_send` int(11) DEFAULT NULL COMMENT '是否流水发送到mbs系统',\n  `edition_account_id` varchar(36) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '版本账号ID',\n  `balance` varchar(50) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '账户余额',\n  `balance_update_time` timestamp NULL DEFAULT NULL COMMENT '账户余额更新时间',\n  `account_status` varchar(50) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '从视图获取的账户状态',\n  `balance_check` tinyint(4) DEFAULT NULL COMMENT '是否余额校验：1 是（默认） 0否',\n  PRIMARY KEY (`id`)\n) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_bin COMMENT='银行账户'",
