            "DDL": "CREATE TABLE `sys_login_log` (\n  `id` varchar(32) COLLATE utf8mb4_bin NOT NULL COMMENT '主键',\n  `operate_time` timestamp NULL DEFAULT NULL COMMENT '访问时间',\n  `operator` varchar(32) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '访问人员',\n  `ip` varchar(20) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '来访IP',\n  `times` int(10) DEFAULT NULL COMMENT '耗时(ms)',\n  `response_code` int(11) DEFAULT NULL COMMENT '响应码',\n  `response_message` varchar(100) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '响应消息',\n  `when_created` varchar(20) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '创建时间',\n  PRIMARY KEY (`id`)\n) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_bin COMMENT='系统表-用户登录日志'",
