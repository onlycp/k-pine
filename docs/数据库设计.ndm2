            "updateTime": "2022-03-01 12:16:03",
            "DDL": "CREATE TABLE `sys_task` (\n  `id` varchar(32) COLLATE utf8mb4_bin NOT NULL COMMENT '主键',\n  `name` varchar(100) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '任务名称',\n  `cron` varchar(50) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '定时表达式',\n  `distributed` tinyint(4) DEFAULT NULL COMMENT '是否分布式',\n  `application_id` varchar(32) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '应用ID',\n  `task_type` tinyint(4) DEFAULT '1' COMMENT '任务类型',\n  `task_resource_id` varchar(36) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '任务资源ID',\n  `class_name` varchar(255) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '类名',\n  `enable` tinyint(4) DEFAULT '1' COMMENT '启用状态',\n  `last_execute_status` tinyint(4) DEFAULT NULL COMMENT '最后执行状态 1：成功 0：失败',\n  `last_execute_msg` text COLLATE utf8mb4_bin COMMENT '最后执行错误信息',\n  `last_execute_time` timestamp NULL DEFAULT NULL COMMENT '上次执行时间',\n  `last_execute_take` int(11) DEFAULT NULL COMMENT '上次执行消耗',\n  `lock_status` tinyint(4) DEFAULT '0' COMMENT '锁定状态',\n  `lock_for_most` int(8) DEFAULT '30' COMMENT '最多锁定时长(秒)',\n  `lock_for_least` int(8) DEFAULT '1' COMMENT '最少锁定时长(秒)',\n  `lock_for_time` timestamp NULL DEFAULT NULL COMMENT '锁定时间',\n  `note` text COLLATE utf8mb4_bin COMMENT '备注',\n  `who_created` varchar(32) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '创建人',\n  `when_created` timestamp NULL DEFAULT NULL COMMENT '创建时间',\n  `who_modified` varchar(32) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '修改人',\n  `when_modified` timestamp NULL DEFAULT NULL COMMENT '修改时间',\n  PRIMARY KEY (`id`)\n) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_bin COMMENT='系统表-任务表'",
