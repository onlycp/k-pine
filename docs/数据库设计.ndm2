            "DDL": "CREATE TABLE `sys_notice_record` (\n  `id` varchar(36) COLLATE utf8mb4_bin NOT NULL COMMENT '通知记录ID',\n  `from_who` varchar(36) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '发送人',\n  `to_who` varchar(36) COLLATE utf8mb4_bin NOT NULL COMMENT '接收人',\n  `notice_id` varchar(36) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '关联通知',\n  `is_read` tinyint(2) NOT NULL DEFAULT '0' COMMENT '是否已读，0：未读，1：已读',\n  `read_time` timestamp NULL DEFAULT NULL COMMENT '阅读通知时间',\n  `notice_time` timestamp NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT '接收通知时间',\n  `title` varchar(255) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '通知标题',\n  `content` text COLLATE utf8mb4_bin COMMENT '通知内容',\n  `to_who_name` varchar(255) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '接收人名称',\n  `from_who_name` varchar(255) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '发送人名称',\n  PRIMARY KEY (`id`)\n) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_bin",
