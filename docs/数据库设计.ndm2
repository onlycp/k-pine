            "updateTime": "2022-02-21 11:06:53",
            "DDL": "CREATE TABLE `kw_edition_account` (\n  `id` varchar(36) COLLATE utf8mb4_bin NOT NULL COMMENT '主键',\n  `edition_id` varchar(100) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '版本id',\n  `login_type` int(11) DEFAULT NULL COMMENT '登录类型',\n  `bank_account` varchar(50) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '登录网银账号',\n  `bank_password` varchar(50) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '登录网银密码',\n  `cert_number` varchar(64) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '登录证书号',\n  `ukey_password` varchar(30) COLLATE utf8mb4_bin DEFAULT NULL COMMENT 'ukey密码',\n  `usb_ip` varchar(20) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '云柜ip',\n  `usb_port` varchar(30) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '云柜端口',\n  `usb_group` varchar(20) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '云柜插口',\n  `password_retried` int(11) DEFAULT NULL COMMENT '密码错误次数',\n  `is_ok_key` int(11) DEFAULT NULL COMMENT '是否需要按ok键',\n  `usb_ip_ok` varchar(20) COLLATE utf8mb4_bin DEFAULT NULL COMMENT 'ok_云柜ip',\n  `usb_port_ok` varchar(30) COLLATE utf8mb4_bin DEFAULT NULL COMMENT 'ok_云柜端口',\n  `usb_group_ok` varchar(8) COLLATE utf8mb4_bin DEFAULT NULL COMMENT 'ok_云柜插口',\n  `deleted` tinyint(4) DEFAULT '0' COMMENT '是否删除',\n  `when_created` timestamp NULL DEFAULT NULL COMMENT '创建时间',\n  `when_modified` timestamp NULL DEFAULT NULL COMMENT '修改时间',\n  `who_created` varchar(36) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '创建人',\n  `who_modified` varchar(36) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '修改人',\n  `reserve1` varchar(255) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '备用字段1（客户号）',\n  `reserve2` varchar(255) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '备用字段2',\n  `reserve3` varchar(255) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '备用字段3',\n  `reserve4` varchar(255) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '备用字段4',\n  `reserve5` varchar(255) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '备用字段5',\n  `status` int(11) DEFAULT NULL COMMENT '状态',\n  PRIMARY KEY (`id`)\n) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_bin COMMENT='网银系统版本登录管理表-add'",
