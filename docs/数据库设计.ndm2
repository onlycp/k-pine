            "DDL": "CREATE TABLE `biz_xzicpp_test_and_equipment` (\n  `id` varchar(255) COLLATE utf8mb4_bin NOT NULL COMMENT 'id',\n  `number` varchar(255) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '编号',\n  `name` varchar(255) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '名称',\n  `top_class` tinyint(255) DEFAULT NULL COMMENT '一级分类',\n  `second_class` tinyint(255) DEFAULT NULL COMMENT '二级分类',\n  `service_type` tinyint(255) DEFAULT NULL COMMENT '服务类型',\n  `qualification` varchar(255) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '资质',\n  `specification` varchar(255) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '仪器规格',\n  `requirements` varchar(255) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '测试须知',\n  `supplier` varchar(255) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '供应商',\n  `price` varchar(255) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '价格',\n  `image` varchar(255) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '图片',\n  `shelf_status` tinyint(255) DEFAULT NULL COMMENT '上架状态',\n  `average_time` int(255) DEFAULT NULL COMMENT '平均时长',\n  `satisfaction` decimal(65,0) DEFAULT NULL COMMENT '满意度',\n  `service_times` int(255) DEFAULT NULL COMMENT '服务次数',\n  PRIMARY KEY (`id`)\n) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_bin",
