            "DDL": "CREATE TABLE `kw_bank_account_manager` (\n  `id` varchar(36) COLLATE utf8mb4_bin NOT NULL COMMENT '主键',\n  `pro_id` varchar(36) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '项目id',\n  `pro_pm` varchar(255) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '产品名称',\n  `pro_pm_account` varchar(36) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '产品编码',\n  `customer_manager_name` varchar(100) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '客户经理姓名',\n  `customer_name` varchar(100) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '客户名称',\n  `amount` varchar(50) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '预约金额元',\n  `when_created` timestamp NULL DEFAULT NULL COMMENT '创建时间',\n  `when_modified` timestamp NULL DEFAULT NULL COMMENT '修改时间',\n  `who_created` varchar(36) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '创建人',\n  `who_modified` varchar(36) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '修改人',\n  `reserve1` varchar(255) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '备用字段1',\n  `reserve2` varchar(255) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '备用字段2',\n  `reserve3` varchar(255) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '备用字段3',\n  `reserve4` varchar(255) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '备用字段4',\n  `reserve5` varchar(255) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '备用字段5',\n  `book_number` varchar(100) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '预约编号',\n  `customer_number` varchar(100) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '客户编号',\n  `customer_manager_number` varchar(100) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '客户经理姓名',\n  `book_time` varchar(100) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '预约时间',\n  PRIMARY KEY (`id`)\n) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_bin COMMENT='项目客户经理表'",
