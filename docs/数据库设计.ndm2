            "DDL": "CREATE TABLE `dev_api` (\n  `id` varchar(32) COLLATE utf8mb4_bin NOT NULL DEFAULT '' COMMENT '主键',\n  `api_name` varchar(50) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '接口名称',\n  `application_id` varchar(32) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '归属应用ID',\n  `api_url` varchar(128) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '接口路径',\n  `api_note` text COLLATE utf8mb4_bin COMMENT '接口描述',\n  `api_tags` varchar(128) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '标签',\n  `api_method` varchar(32) COLLATE utf8mb4_bin DEFAULT 'get' COMMENT '请求方式',\n  `api_argv_type` int(4) DEFAULT NULL COMMENT '参数组装方式',\n  `api_req_argv` text COLLATE utf8mb4_bin COMMENT '请求参数',\n  `api_rsp_argv` text COLLATE utf8mb4_bin COMMENT '响应结果',\n  `api_result_handler` varchar(128) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '结果处理类',\n  `who_created` varchar(32) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '创建人',\n  `when_created` varchar(20) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '创建时间',\n  `who_modified` varchar(32) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '修改人',\n  `when_modified` varchar(20) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '修改时间',\n  `api_flow_id` varchar(50) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '流程ID',\n  `api_code` varchar(50) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '接口编码',\n  `call_type` int(4) DEFAULT NULL COMMENT '调试方式',\n  PRIMARY KEY (`id`)\n) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_bin",
