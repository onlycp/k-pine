            "DDL": "CREATE TABLE `biz_monitor` (\n  `id` varchar(36) COLLATE utf8mb4_bin NOT NULL COMMENT '主键',\n  `name` varchar(100) COLLATE utf8mb4_bin NOT NULL COMMENT '名称',\n  `img` varchar(100) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '图片',\n  `note` text COLLATE utf8mb4_bin COMMENT '描述',\n  `app_key` varchar(100) COLLATE utf8mb4_bin DEFAULT NULL COMMENT 'appKey',\n  `url` varchar(500) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '回调url',\n  `who_created` varchar(32) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '创建人员',\n  `when_created` timestamp NULL DEFAULT NULL COMMENT '创建时间',\n  `who_modified` varchar(32) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '修改人员',\n  `when_modified` timestamp NULL DEFAULT NULL COMMENT '修改时间',\n  PRIMARY KEY (`id`)\n) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_bin COMMENT='监控定义表'",
