            "DDL": "CREATE TABLE `sys_notice` (\n  `id` varchar(36) COLLATE utf8mb4_bin NOT NULL COMMENT '消息ID',\n  `title` varchar(255) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '通知标题',\n  `content` text COLLATE utf8mb4_bin COMMENT '通知内容',\n  `type` tinyint(2) DEFAULT NULL COMMENT '通知类型，1：系统维护通知，2：公告',\n  `status` tinyint(2) NOT NULL DEFAULT '1' COMMENT '启用状态：0：待启用，1：已启用',\n  `who_created` varchar(36) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '创建人',\n  `when_created` timestamp NULL DEFAULT NULL COMMENT '创建时间',\n  `who_modified` varchar(36) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '更新人',\n  `when_modified` timestamp NULL DEFAULT NULL COMMENT '更新时间',\n  `deleted` tinyint(1) DEFAULT NULL COMMENT '逻辑删除，0：未删除，1：已删除',\n  PRIMARY KEY (`id`)\n) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_bin",
