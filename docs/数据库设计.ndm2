            "DDL": "CREATE TABLE `sys_data_resource` (\n  `id` varchar(32) COLLATE utf8mb4_bin NOT NULL COMMENT '主键',\n  `name` varchar(50) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '名称',\n  `table_name` varchar(50) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '表名',\n  `label_field` varchar(50) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '标签列',\n  `value_field` varchar(50) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '值列',\n  `query_sql` text COLLATE utf8mb4_bin COMMENT '查询SQL',\n  `is_tree` tinyint(4) DEFAULT NULL COMMENT '是否树形结构',\n  `is_only_leaf` tinyint(4) DEFAULT NULL COMMENT '是否只选树叶',\n  `status` tinyint(4) DEFAULT NULL COMMENT '启用状态',\n  `who_created` varchar(32) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '创建人员',\n  `when_created` varchar(20) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '创建时间',\n  `who_modified` varchar(32) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '修改人员',\n  `when_modified` varchar(20) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '修改时间',\n  `extra_sql` text COLLATE utf8mb4_bin COMMENT '权限附加SQL',\n  PRIMARY KEY (`id`)\n) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_bin COMMENT='系统表-数据资源配置'",
