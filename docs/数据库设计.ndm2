            "DDL": "CREATE TABLE `kw_queue_task` (\n  `id` varchar(36) COLLATE utf8mb4_bin NOT NULL COMMENT '主键',\n  `name` varchar(255) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '任务名称',\n  `data` text COLLATE utf8mb4_bin COMMENT '任务数据',\n  `error` varchar(4000) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '错误信息',\n  `description` varchar(4000) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '备注',\n  `type` int(11) DEFAULT NULL COMMENT '任务类型',\n  `when_created` timestamp NULL DEFAULT NULL COMMENT '创建时间',\n  `when_modified` timestamp NULL DEFAULT NULL COMMENT '修改时间',\n  `who_created` varchar(36) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '创建人',\n  `who_modified` varchar(36) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '修改人',\n  `status` int(11) DEFAULT NULL COMMENT '执行状态',\n  `deleted` tinyint(4) DEFAULT '0' COMMENT '删除标识',\n  PRIMARY KEY (`id`)\n) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_bin COMMENT='队列任务表-系统表'",
