            "DDL": "CREATE TABLE `kw_water` (\n  `id` varchar(36) COLLATE utf8mb4_bin NOT NULL COMMENT '流水',\n  `receipt_id` varchar(36) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '回单id',\n  `account_id` varchar(36) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '账户id',\n  `transaction_date` timestamp NULL DEFAULT NULL COMMENT '交易日期',\n  `transaction_time` timestamp NULL DEFAULT NULL COMMENT '交易时间',\n  `transaction_type` varchar(50) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '交易类型',\n  `currency` int(11) DEFAULT NULL COMMENT '币种',\n  `account` varchar(50) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '账户',\n  `account_name` varchar(100) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '账户名称',\n  `revenue` int(11) DEFAULT NULL COMMENT '收支方向',\n  `cash_transfer` int(11) DEFAULT NULL COMMENT '现/转',\n  `transaction_amount` varchar(50) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '交易金额',\n  `account_balance` varchar(50) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '账户余额',\n  `other_account` varchar(50) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '对方帐号',\n  `other_name` varchar(100) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '对方名称',\n  `other_bank_name` varchar(100) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '对方行名',\n  `purpose` varchar(255) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '用途',\n  `abstract_info` varchar(255) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '摘要',\n  `product_name` varchar(100) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '产品名称',\n  `serial_number` varchar(100) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '流水号',\n  `remark` longtext COLLATE utf8mb4_bin COMMENT '备注',\n  `data_source` int(11) DEFAULT NULL COMMENT '数据来源',\n  `register_time` timestamp NULL DEFAULT NULL COMMENT '登记时间',\n  `other_data` longtext COLLATE utf8mb4_bin COMMENT '其他数据',\n  `status` int(11) DEFAULT NULL COMMENT '数据状态',\n  `abnormal` int(11) DEFAULT NULL COMMENT '流水是否异常',\n  `abnormal_status` int(11) DEFAULT NULL COMMENT '流水异常处理状态',\n  `has_receipt` int(11) DEFAULT NULL COMMENT '是否有回单',\n  `deleted` tinyint(4) DEFAULT '0' COMMENT '删除标识',\n  `date_index` int(11) DEFAULT NULL COMMENT '数据序号',\n  PRIMARY KEY (`id`)\n) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_bin COMMENT='流水管理表'",
