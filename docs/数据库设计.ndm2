            "DDL": "CREATE TABLE `sys_file` (\n  `id` varchar(32) COLLATE utf8mb4_bin NOT NULL COMMENT '主键',\n  `file_name` varchar(100) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '文件名称',\n  `file_original_name` varchar(100) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '原始文件名',\n  `file_size` int(11) DEFAULT NULL COMMENT '文件大小(Byte)',\n  `file_ext` text COLLATE utf8mb4_bin COMMENT '文件扩展名',\n  `file_md5` varchar(40) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '文件MD5值',\n  `file_from` varchar(50) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '文件来源',\n  `save_type` int(4) DEFAULT NULL COMMENT '存储方式 0：数据库 1：本地磁盘',\n  `file_path` varchar(100) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '存储路径',\n  `file_content` longtext COLLATE utf8mb4_bin COMMENT '文件内容，只有存数据库时才有值',\n  `who_created` varchar(32) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '创建人员',\n  `when_created` varchar(20) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '创建时间',\n  `who_modified` varchar(32) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '修改人员',\n  `when_modified` varchar(20) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '修改时间',\n  PRIMARY KEY (`id`)\n) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_bin COMMENT='系统表-文件表'",
