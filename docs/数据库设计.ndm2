        "views": [
          {
            "objectType": "View_MYSQL",
            "name": "view_kw_bank_account",
            "selectStatement": "select `km`.`bank_name` AS `bank_name`,`ke`.`name` AS `name`,`kea`.`bank_account` AS `bank_account`,`kea`.`reserve1` AS `khh`,`kea`.`cert_number` AS `cert_number`,`kea`.`bank_password` AS `bank_password`,`ke`.`path` AS `path`,`kea`.`ukey_password` AS `ukey_password`,`kea`.`usb_ip` AS `usb_ip`,`kea`.`usb_port` AS `usb_port`,`kea`.`usb_group` AS `usb_group`,`kea`.`is_ok_key` AS `is_ok_key`,`kea`.`usb_ip_ok` AS `usb_ip_ok`,`kea`.`usb_port_ok` AS `usb_port_ok`,`kea`.`usb_group_ok` AS `usb_group_ok`,`kbae`.`pro_name` AS `pro_name`,`kba`.`account` AS `account`,`kbae`.`trust_accounting` AS `trust_accounting`,`kba`.`cxpl` AS `cxpl`,`kbae`.`in_date` AS `in_date`,`kbae`.`up_date` AS `up_date`,`kba`.`cancel_account_time` AS `cancel_account_time`,`kba`.`status` AS `status` from ((((`kw_edition_account` `kea` left join `kw_edition` `ke` on((`kea`.`edition_id` = `ke`.`id`))) left join `kw_mechanism` `km` on((`ke`.`mechanism_id` = `km`.`id`))) left join `kw_bank_account` `kba` on((`kea`.`id` = `kba`.`edition_account_id`))) left join `kw_bank_account_expand` `kbae` on((`kbae`.`account` = `kba`.`account`))) order by `km`.`bank_name`,`ke`.`name`",
            "viewAlgorithm": "UNDEFINED",
            "sqlSecurity": "DEFINER",
            "checkOption": "",
            "definer": "`root`@`%`",
            "oldName": "view_kw_bank_account",
            "isUpdatable": true
          }
        ]
      }
    ]
  },
