      "execute": {
        "script": {
          "type": "js",
          "params": [],
          "content": "\nconst pinezipDir = \"upload/package/pinezip/\" + context.sys.uuid\n\n// 打包zip\nlet targetFile = pinezipDir + \".pinezip\"\nconst result = kutils.zip(pinezipDir, targetFile, \"\")\n\n// 删除压缩目录\nkutils.fileDelete(pinezipDir)\n\n// 返回下载路径\ntargetFile = targetFile.substring(7) // 去除 upload/\nsetResult(\"targetFile\", targetFile)\nsetResult(\"targetResult\", JSON.stringify({ path: targetFile }))\n\nconst exportDataJson = getResult(\"exportData\")\nsetResult(\"exportDataJson\", JSON.stringify(exportDataJson))\n\n\nconst applicationConfig = getResult(\"applicationConfig\")\nsetResult(\"exportVersion\", applicationConfig?.version || \"\")"
        }
      }
    },
